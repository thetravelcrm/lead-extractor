# Copy this file to .env and fill in your values

# Path to Google Service Account credentials JSON (for Google Sheets integration)
GOOGLE_CREDENTIALS_PATH=./credentials.json

# Flask secret key (change to a random string in production)
FLASK_SECRET_KEY=change-me-to-a-random-secret-string

# Set to true to enable Flask debug mode (development only)
FLASK_DEBUG=false

# Max concurrent scraping jobs allowed at one time
MAX_CONCURRENT_JOBS=3
